# Discord Bot Tokens — persistent agents only
DIRECTOR_TOKEN=
AUDITOR_TOKEN=
EFFICIENCY_DIRECTOR_TOKEN=

# Discord Server
# Note: the Director bot requires MANAGE_CHANNELS and MANAGE_WEBHOOKS permissions
# in the server to create per-project channels automatically.
DISCORD_GUILD_ID=
APPROVAL_TIMEOUT_MS=1800000

# Org-wide Discord Channel IDs
DISCORD_CHANNEL_DIRECTOR=
DISCORD_CHANNEL_EFFICIENCY=
DISCORD_CHANNEL_APPROVALS=
DISCORD_CHANNEL_ALERTS=

# Claude API — optional but recommended for Director tier
# When set, Director uses Claude API instead of Ollama for spec generation
ANTHROPIC_API_KEY=

# Ollama — used by all agents; Director falls back to Ollama if ANTHROPIC_API_KEY is unset
OLLAMA_BASE_URL=http://127.0.0.1:11434
DIRECTOR_MODEL=claude-opus-4-7
MANAGER_MODEL=llama3.1:8b
WORKER_MODEL=llama3.2:latest

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=stupeterscoaching
GITHUB_REPO=agent-dev-team

# bessemer-state — shared estimation history across all Bessemer tools
# Defaults to usebessemer/bessemer-state; override only if self-hosting
BESSEMER_STATE_OWNER=usebessemer
BESSEMER_STATE_REPO=bessemer-state

# Per-project values (set at runtime by PM agent)
# DISCORD_WEBHOOK_WORKERS=
# PM_TOKEN=
# TECHLEAD_TOKEN=

# Optional — separate GitHub account for Tech Lead
# When set, Tech Lead uses formal PR reviews (APPROVE / REQUEST_CHANGES) instead of comments.
# This requires a second GitHub PAT from a different account; GitHub prevents self-approval.
# TECHLEAD_GITHUB_TOKEN=

# GitHub webhooks — optional; pollers run at 5-minute interval as fallback when unset
# WEBHOOK_URL is the public base URL GitHub can reach (e.g. from ngrok or a deployed host).
# For local dev: run `ngrok http 3000` and set WEBHOOK_URL=https://<ngrok-id>.ngrok.io
# WEBHOOK_URL=
# WEBHOOK_PORT=3000
# GITHUB_WEBHOOK_SECRET=

# SQLite state file — defaults to ./state/agent-dev-team.db
# DB_PATH=