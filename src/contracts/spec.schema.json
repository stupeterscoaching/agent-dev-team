{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Project spec generated by the Director agent",
  "type": "object",
  "required": ["projectName", "projectType", "brief", "architecture", "deliverables"],
  "properties": {
    "projectName": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "maxLength": 30
    },
    "projectType": {
      "type": "string",
      "enum": ["cli", "web-app", "api-service", "data-pipeline", "docs-site"]
    },
    "brief": {
      "type": "object",
      "required": ["problemStatement", "desiredOutcome"],
      "properties": {
        "problemStatement": { "type": "string" },
        "desiredOutcome": { "type": "string" },
        "constraints": {
          "type": "object",
          "properties": {
            "technical": { "type": "array", "items": { "type": "string" } }
          }
        },
        "antiGoals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "architecture": {
      "type": "object",
      "required": ["overview", "components", "techStack"],
      "properties": {
        "overview": { "type": "string" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "techStack": {
          "type": "object",
          "required": ["language", "runtime", "packages"],
          "properties": {
            "language": { "type": "string" },
            "runtime": { "type": "string" },
            "packages": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "description", "acceptanceCriteria"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["code", "docs", "research"] },
          "description": { "type": "string" },
          "acceptanceCriteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
